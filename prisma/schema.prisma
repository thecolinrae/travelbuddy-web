// TravelBuddy web — PostgreSQL schema
// Replaces the Google Drive file-per-trip storage model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User profile (keyed by Google OAuth sub) ────────────────────────────────

model Profile {
  id                String   @id               // Google OAuth sub (providerAccountId)
  email             String   @unique
  name              String?
  avatarUrl         String?
  preferredCurrency String   @default("CAD")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  trips             Trip[]
  receivedShares    TripShare[] @relation("SharedWithUser")
  batchJobs         BatchJob[]
  notifications     Notification[]
}

// ── Trip ─────────────────────────────────────────────────────────────────────

model Trip {
  id                String    @id @default(cuid())
  userId            String
  name              String
  destination       String    @default("")
  destinations      String[]  @default([])
  startDate         String?                     // YYYY-MM-DD
  endDate           String?                     // YYYY-MM-DD
  status            String    @default("upcoming")
  coverEmoji        String    @default("✈️")
  coverPhotoUrl     String?                     // destination photo URL (Google Places CDN or future: Unsplash)
  itineraryMd       String?                     // AI-generated markdown (display only)
  notes             String?                     // freeform user notes (markdown)
  budgetGoal        Float?
  categoryGoals     Json?                       // Partial<Record<BudgetItemCategory, number>>
  preferredCurrency String    @default("CAD")
  ownerEmail        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  profile           Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  timelineEvents    TimelineEvent[]
  transportLegs     TransportLeg[]
  activities        Activities?
  artifacts         Artifact[]
  shares            TripShare[]
  batchJobs         BatchJob[]
  notifications     Notification[]

  @@index([userId, createdAt(sort: Desc)])
}

// ── Timeline events (discriminated union stored as JSONB) ────────────────────

model TimelineEvent {
  id              String    @id @default(cuid())
  tripId          String
  eventType       String                        // 'flight', 'hotel', 'otherTransportation', 'expense', 'activity'
  eventSubtype    String?                       // 'departure', 'arrival', 'check_in', 'check_out', etc.
  data            Json                          // full typed TimelineEvent (discriminated union)
  eventDate       String?                       // YYYY-MM-DD for date-based indexing
  sortUtc         DateTime?                     // accurate chronological ordering
  journeyId       String?                       // groups dep+arr events from the same flight booking
  legId           String?                       // user-defined transport leg (soft ref to TransportLeg.id)
  artifactSources String[]  @default([])
  createdAt       DateTime  @default(now())

  trip            Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, eventDate])
  @@index([tripId, sortUtc])
  @@index([tripId, journeyId])
  @@index([tripId, legId])
}

// ── Transport legs (user-defined groupings of transport events) ───────────────

model TransportLeg {
  id            String   @id @default(cuid())
  tripId        String
  name          String?                         // auto-generated or user-set, e.g. "AUS → NRT"
  nameIsCustom  Boolean  @default(false)        // true when user has manually renamed
  order         Int                             // display order within the trip
  createdAt     DateTime @default(now())

  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, order])
}

// ── Activities (suggestions + saved) ────────────────────────────────────────

model Activities {
  id          String   @id @default(cuid())
  tripId      String   @unique
  destination String?
  data        Json                              // Activity[]
  updatedAt   DateTime @updatedAt

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// ── Uploaded artifact files ──────────────────────────────────────────────────

model Artifact {
  id             String   @id @default(cuid())
  tripId         String
  fileName       String
  mimeType       String
  storagePath    String                         // S3 object key: artifacts/{tripId}/{fileName}
  size           BigInt?
  gmailMessageId String?                        // Gmail message ID — set when artifact came from a Gmail import
  gmailLabelId   String?                        // Gmail label ID — set when artifact came from a label import
  gmailLabelName String?                        // Human-readable label name at time of import
  createdAt      DateTime @default(now())

  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([tripId, gmailLabelId])
}

// ── Trip sharing ─────────────────────────────────────────────────────────────

model TripShare {
  id               String   @id @default(cuid())
  tripId           String
  ownerId          String
  sharedWithEmail  String
  sharedWithUserId String?                      // null until recipient signs in
  createdAt        DateTime @default(now())

  trip             Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sharedWithUser   Profile? @relation("SharedWithUser", fields: [sharedWithUserId], references: [id])

  @@unique([tripId, sharedWithEmail])
  @@index([sharedWithEmail])
  @@index([sharedWithUserId])
}

// ── Async batch jobs (Anthropic Message Batches API) ─────────────────────────

model BatchJob {
  id               String         @id @default(cuid())
  userId           String
  tripId           String
  anthropicBatchId String         @unique
  status           String         @default("pending") // pending | processing | completed | failed
  destinations     String[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  profile          Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip             Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  notifications    Notification[]

  @@index([userId, status])
  @@index([tripId])
}

// ── User notifications ────────────────────────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  userId     String
  tripId     String
  batchJobId String?
  type       String                          // activities_generating | activities_ready
  read       Boolean   @default(false)
  createdAt  DateTime  @default(now())

  profile    Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  batchJob   BatchJob? @relation(fields: [batchJobId], references: [id])

  @@index([userId, read])
  @@index([tripId])
}
