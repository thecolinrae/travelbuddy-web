# ── Cloudflare DNS (for Let's Encrypt DNS-01 challenge) ───────────────────────
# Create an API token at https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Zone → DNS → Edit (scoped to screwball.ca zone)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://travelbuddy.screwball.ca:3000

# ── Auth Hub ──────────────────────────────────────────────────────────────────
# Register travelbuddy as an OIDC client in auth-hub admin (auth.screwball.ca/admin)
# Redirect URIs to add: {NEXTAUTH_URL}/api/auth/callback/auth-hub
# auth-hub provides: user auth (OIDC), Google OAuth tokens (Gmail), Anthropic API key
AUTH_HUB_URL=https://auth.screwball.ca
AUTH_HUB_CLIENT_ID=travelbuddy
AUTH_HUB_CLIENT_SECRET=your-client-secret

# ── Google Maps ───────────────────────────────────────────────────────────────
# Enable Maps JavaScript API + Places API + Geocoding API in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-key

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: defaults to the local db container (set in docker-compose.yml — no need to set here)
# Production: points to the shared homelab-infra PostgreSQL container
DATABASE_URL=postgresql://travelbuddy:your-password@homelab_db:5432/travelbuddy

# ── S3-Compatible File Storage ────────────────────────────────────────────────
# Local dev: MinIO (set automatically by docker-compose.yml)
# Production options:
#   AWS S3:         S3_ENDPOINT=https://s3.amazonaws.com, S3_REGION=us-east-1
#   Cloudflare R2:  S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com, S3_REGION=auto
#   Backblaze B2:   S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com, S3_REGION=us-west-004
#   Self-hosted:    S3_ENDPOINT=http://your-minio-host:9000, S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_ENDPOINT — set this when S3_ENDPOINT uses an internal hostname that browsers
# cannot reach (e.g. Docker service names). Presigned download URLs will have their origin
# rewritten to this value before being sent to the browser.
# Self-hosted MinIO via Caddy proxy: S3_PUBLIC_ENDPOINT=https://travelbuddy.screwball.ca/storage
S3_PUBLIC_ENDPOINT=
S3_BUCKET=travelbuddy
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ── agents-web integration (optional) ─────────────────────────────────────────
# When all three vars are set, the chat assistant delegates to an agents-web agent
# instead of calling Claude directly. Leave unset to use the built-in chat.
#
# AGENTS_WEB_URL: base URL of your agents-web instance
# CHAT_AGENT_ID: ID of the agents-web agent to use for trip chat
# AGENTS_WEB_API_KEY: service API key from agents-web (POST /api/v1/keys)
AGENTS_WEB_URL=
CHAT_AGENT_ID=
AGENTS_WEB_API_KEY=
